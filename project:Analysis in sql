select * from superstore;

-- which market generates the most sales and profit?
select market,
sum(profit) as totalprofit,
sum(sales) as totalsales, 
rank() over(order by sum(sales) desc) as sales_rank,
rank() over(order by sum(profit) desc ) as profit_rank
from superstore
group by market
order by totalsales desc;

-- APAC market has the highest both total profit and total sales among all
-- total margin APAC  HAS BROUGHT  12.17% 

-- checking for all margins for all market has brought
select market,
sum(sales) as totalsales,
sum(profit) as totalprofit,
sum(profit)/sum(sales)*100 as margin,
rank() over(order by sum(sales) desc) as sales_rank,
rank() over(order by sum(profit) desc) as profit_rank,
rank() over(order by sum(profit)/sum(sales)*100 desc ) as margin_rank
from superstore
group by market
order by margin_rank desc;

-- from this finding
-- here canada has brought highest margin among all of them i.e 26.62 cents every dollar earned
-- as APAC has highest sales and profit but it has margin rank at 4th postion 
-- with only 12.18 cents every dollar earned 
-- the concern here is EMEA has lowest rank and margin i.e only 5.44 cents among all decent sales 
-- need some investivation at -- EMEA market

select * from superstore;
-- Why does EMEA have the lowest profit margin? 
 -- Is it high discounts,high shipping costs, or both?
select market, avg(discount)*100 as total_discount , avg(shipping_cost) as total_shipping_cost,
rank() over (order by avg(discount)*100 desc) discount_rank,
rank() over(order by  avg(shipping_cost) desc) shippingcost_rank 
from superstore
group by market;
-- here EMEA therefore has given heavy discounts it clearly lies on rank 1st among 7 th of the market 
-- highest shipping cost given is of market APAC 
-- EMEA has given highest discount which is killing profit margin 
-- i consider recommending them to lower their discounts 
-- shipping cost for EMEA is not an issue 


-- Which product category generates the most sales 
-- and profit? 
-- Does heavy discounting affect any category's margin?

select * from superstore;

select category , sum(sales) , sum(profit),
rank() over(order by sum(sales) desc) as sales_rank,
rank() over(order by sum(profit) desc) as profit_rank
from superstore
group by category 
order by sales_rank ; 
-- here we see that technology category has highest sales and profit
-- furniture has second highest sales but has last profit ,maybe discount id causing furniture
-- to have lowest profit in category


-- checking discount affecting margin
select category, avg(discount)*100 ,sum(profit)/sum(sales) *100,
rank() over(order by avg(discount)*100 desc) as discount_rank,
rank() over(order by sum(profit)/sum(sales)*100 desc) as margin_rank
from superstore
group by category
order by category;
-- furniture category has highest discount causing lowest margin
-- recomendation reduce furniture discount to improve margin

-- What is the maximum days to ship ?
select datediff(ship_date, order_date) as daystoship,
count(*) as order_count
from superstore
group by daystoship
order by daystoship desc;
-- it took maximum of 7 days to ship 3055 product
-- most order took 4 days to be shipped
-- 2598 products were shipped on same day


