    order_id VARCHAR(50),
    order_date VARCHAR(20),
    ship_date VARCHAR(20),
    ship_mode VARCHAR(50),
    customer_name VARCHAR(100),
    segment VARCHAR(50),
    country VARCHAR(100),
    state VARCHAR(100),
    market VARCHAR(50),
    region VARCHAR(50),
    product_id VARCHAR(50),
    category VARCHAR(50),
    sub_category VARCHAR(50),
    product_name VARCHAR(255),
    sales VARCHAR(20),
    quantity VARCHAR(10),
    discount VARCHAR(10),
    profit VARCHAR(20),
    shipping_cost VARCHAR(20),
    order_priority VARCHAR(50),
    year VARCHAR(10)
);
