-- find customers who are most likely to default or cause 
-- problems for the bank
-- here low credit score and high loan amounts defines high risks

create temporary table high_risk_customers as 
select c.customer_id,
c.first_name,
c.last_name,
c.credit_score,
sum(l.loan_amount) as total_loan_amount
from customers as c
join loans as l
on c.customer_id=l.customer_id
group by  c.customer_id,c.first_name,c.last_name,c.credit_score
having credit_score<600 and total_loan_amount>300000 
order by total_loan_amount desc;
select count(*)as total from high_risk_customers;
select round(count(*)*100/(select count(*) from customers),2) as risk_percentage from high_risk_customers;
-- 3.87% customers are high most likely to default or cause 
-- problems for the bank they have low credit scores(<600) and
-- high loan exposure(>300k). This represents significant financial risk 
-- and should be closely monitored by the bank.





  


