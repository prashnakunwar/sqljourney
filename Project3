-- how many loans started in each year or month
desc loans;
with monthh as(
select
date_format(start_date , '%y-%m') as month,
count(*) as total_loan_started,
row_number() over(order by date_format(start_date , '%y-%m') ) as rn
from loans
group by date_format(start_date,'%y-%m')
order by month asc),

yearr as(
select 
date_format(start_date, '%y') as year,
count(*) as total_loan_start_year,
row_number() over(order by date_format(start_date, '%y')) as rn
from loans
group by date_format(start_date, '%y') 
order by year asc )

select 
m.month,
m.total_loan_started,
y.year,
y.total_loan_start_year
from monthh m
left join yearr y
on m.rn=y.rn;
